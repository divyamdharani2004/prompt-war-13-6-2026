# Copy this file to ".env" and add a key to enable real AI features.
# Without any key, MindSpace runs in DEMO MODE (locally simulated responses).
#
# Provider precedence: OpenRouter is used if set, else Anthropic, else demo.

# ── Option A: OpenRouter (recommended — one key, many models incl. free tiers) ──
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Pick any model from https://openrouter.ai/models — examples:
#   anthropic/claude-3.5-sonnet         (high quality)
#   openai/gpt-4o-mini                  (cheap, fast)
#   meta-llama/llama-3.3-70b-instruct:free   (free tier)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── Option B: Anthropic API direct ──
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: public URL (used for OpenRouter ranking headers) and port
# APP_URL=http://localhost:3000
# PORT=3000
