{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "lib/**", "middleware/**", "routes/**", "app.js"]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/api/index.js" }]
}
